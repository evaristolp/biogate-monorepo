# BioGate environment variables (copy to .env and fill in; do not commit .env)
# Required for API + DB
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Claude vendor normalization
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Email (Resend) — audit report + certificate PDF to user
RESEND_API_KEY=re_xxxxxxxxxxxx
BIOGATE_EMAIL_FROM=BioGate <noreply@yourdomain.com>

# Optional: SMTP fallback if Resend not used
# BIOGATE_EMAIL_FROM=noreply@yourdomain.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Optional: API key for protected routes (leave unset to disable)
# BIOGATE_API_KEY=

# Optional: Free-tier usage limit per identity (leave unset to disable)
# BIOGATE_FREE_CREDITS=5

# Optional: Base URL for certificate QR code / verify link
# BIOGATE_BASE_URL=https://biogate.us

# Optional: CORS origins for browser requests (comma-separated). Set to your frontend URL(s).
# CORS_ORIGINS=https://biogate.us,https://www.biogate.us

# --- v0 / Next.js frontend (set these in v0 → Settings → Vars, not in backend .env) ---
# BIOGATE_API_BASE_URL = your FastAPI backend URL, e.g. https://api.biogate.io or http://localhost:8000
# BIOGATE_API_KEY = optional; only if your backend requires auth (BIOGATE_API_KEY set above)
# NEXT_PUBLIC_API_BASE_URL = same as BIOGATE_API_BASE_URL (for client-side links, e.g. certificate verification)
